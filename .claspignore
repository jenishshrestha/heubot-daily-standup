# Only the .gs files and appsscript.json should ship to Apps Script.
# Everything else stays local.

# Big trees we never want clasp to even traverse.
node_modules/**
.git/**
.claude/**
.vscode/**

# Everything except the source files.
**/**
!Code.gs
!Admin.gs
!Card.gs
!Database.gs
!Jira.gs
!Bot.gs
!appsscript.json
